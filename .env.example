# Flask Application Configuration
FLASK_APP=app.py
FLASK_ENV=development
DEBUG=True

# Server binding
PORT=5001
# WORKERS=4
# TIMEOUT=30

# SQLite storage (paths are inside the container when using docker-compose)
SQLITE_DB_DIR=./database_data
SQLITE_DB_NAME=jugglefit.db
# SQLITE_BACKUP_DIR=./database_backups

# Super-admin (env credentials). Works at /auth/login and /admin/login.
# Grants full admin access + the ability to grant/revoke admin on users.
SUPER_ADMIN_USER=Admin
SUPER_ADMIN_PASSWORD=change_me

# Security — REQUIRED in production (FLASK_ENV=production). The app will
# refuse to start without it. Generate one with:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change_this_to_a_random_secret_string

# Off-box backup (optional). Run `rclone config` on the host first.
# RCLONE_REMOTE=gdrive:jugglefit-backups
# BACKUP_KEEP_LOCAL=1
# BACKUP_REMOTE_KEEP_DAILY=14
# BACKUP_REMOTE_KEEP_WEEKLY=8
